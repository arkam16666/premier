<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Kanit:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&family=Sarabun:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="menubar.css">
    <link rel="stylesheet" href="edit_sale.css">
    <link rel="stylesheet" href="model.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <title>Document</title>
</head>

<body>
    <aside class="sidebar">
        <div class="logo">
            <h2>ระบบ ERP</h2>
            <span>ระดับจงกร</span><br>
        </div>

        <nav class="menu">
            <a href="<%= baseUrl %>/" class="active">Dashboard</a>
            <a href="<%= baseUrl %>/sale_pr" class="buy">เสนอซื้อ</a>
            <a href="#">เสนอขาย</a>
            <a href="#">คลังสินค้า</a>
        </nav>
    </aside>
    <main style="padding: 20px;">


        <% if (order && order.length> 0) { %>
            <h1>แก้ไขข้อมูลการเสนอขาย สำหรับ <%= order[0]['ลูกค้า-ผู้ขาย'] %>
            </h1>
            <% } else { %>
                <h1>แก้ไขข้อมูลการเสนอขาย</h1>
                <% } %>
            <div class="table-responsive" style="overflow-x: auto; width: 100%;">
                <table>
                        <thead>
                            <tr>
                                <% if (order && order.length> 0) { %>
                                    <% Object.keys(order[0]).forEach(h=> { %>
                                        <th>
                                            <%= h %>
                                        </th>
                                        <% }) %>
                                            <% } %>
                            </tr>
                        </thead>
                        <tbody class="order">
                            <% if (order && order.length> 0) { %>
                                <% order.forEach(row=> { %>
                                    <tr>
                                        <% Object.values(row).forEach(val=> { %>
                                            <td>
                                                <%= val %>
                                            </td>
                                            <% }) %>


                                    </tr>
                                    <% }) } else { %>
                                        <tr>
                                            <td colspan="100%" style="text-align: center;">ไม่มีข้อมูล</td>
                                        </tr>
                                        <% } %>
                        </tbody>
                    </table>
                </div>

                <form action="/edit_sale" method="GET" class="search-form">
                            <input type="hidden" name="id" value="<%= idToEdit %>">
                            <div class="search-input-group">
                                <i class="fas fa-search"></i>
                                <input type="text" name="search" value="<%= search %>"
                                    placeholder="ค้นหาชื่อสินค้า" class="search-input">
                            </div>
                            <button type="submit" class="btn-search">
                                <i class="fas fa-search"></i> ค้นหา
                            </button>
                            <a href="/sale_pr" class="btn-clear">
                                <i class="fas fa-sync-alt"></i> ล้างค่า
                            </a>
                </form>

                    <div class="table-responsive" style="overflow-x: auto; width: 100%;">
                        <table>
                            <thead>
                                <tr>
                                    <% if (sale_pr && sale_pr.length> 0) { %>
                                        <% Object.keys(sale_pr[0]).forEach(h=> { %>
                                            <th>
                                                <%= h %>
                                            </th>
                                            <% }) %>
                                                <th style="text-align: center;">จัดการ</th>

                                                <% } %>
                                </tr>
                            </thead>
                            <tbody id="salePrBody">
                                <% if (sale_pr && sale_pr.length> 0) { %>
                                    <% sale_pr.forEach(row=> { %>
                                        <tr class="item" data-product="<%= row['สินค้า'] %>">
                                            <% Object.values(row).forEach(val=> { %>
                                                <td>
                                                    <%= val %>
                                                </td>
                                                <% }) %>
                                                <td style="text-align: center;">
                                                    <input type="checkbox" class="item-checkbox"
                                                        value="<%= row['สินค้า'] %>">
                                                </td>
                                        </tr>

                                        <% }) } else { %>
                                            <tr>
                                                <td colspan="100%" style="text-align: center;">ไม่มีข้อมูล</td>
                                            </tr>
                                            <% } %>
                            </tbody>
                        </table>
                    </div>
                        <div class="btn">

                            <button type="button" id="btnConfirmDelete" onclick="confirmDelete()">ยืนยัน</button>
                            <div class="add">

                                <button type="button" class="btn-add" onclick="openModal()">
                                    <i class="fas fa-plus"></i> เพิ่ม
                                </button>

                                <%- include('modal.ejs') %>

                                    <script src="model.js"></script>
                                    <button type="button" id="btnSoftDelete" onclick="softDelete()">ลบ</button>
                            </div>
                        </div>
    </main>

    <script>
        // ย้ายข้อมูลมาไว้ที่นี่เพื่อให้เข้าถึงได้แน่นอน
        var allProducts = <%- JSON.stringify(allProducts || []) %>;
        var currentEditId = '<%= idToEdit %>';
        var pendingDeletes = [];

        console.log('Page loaded for ID:', currentEditId);
        console.log('Total products loaded:', allProducts.length);

        // ปุ่มลบ: ซ่อนแถวที่ติ๊กเลือกออกจากหน้าจอ + เก็บไว้ใน pendingDeletes
        function softDelete() {
            var checkboxes = document.querySelectorAll('.item-checkbox:checked');
            if (checkboxes.length === 0) {
                alert('กรุณาเลือกรายการที่ต้องการลบ');
                return;
            }

            checkboxes.forEach(function(cb) {
                var row = cb.closest('tr');
                var productCode = row.getAttribute('data-product');

                if (pendingDeletes.indexOf(productCode) === -1) {
                    pendingDeletes.push(productCode);
                }

                row.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
                row.style.opacity = '0';
                row.style.transform = 'translateX(-20px)';
                setTimeout(function() {
                    row.style.display = 'none';
                }, 300);

                cb.checked = false;
            });

            console.log('รอลบ:', pendingDeletes);
        }

        // ปุ่มยืนยัน: ลบจาก Google Sheet จริง
        function confirmDelete() {
            console.log('confirmDelete called. Pending:', pendingDeletes);
            
            if (pendingDeletes.length === 0) {
                alert('ไม่มีรายการที่ต้องลบ');
                return;
            }

            if (!confirm('ยืนยันการลบ ' + pendingDeletes.length + ' รายการออกจากระบบ?')) {
                return;
            }

            var btn = document.getElementById('btnConfirmDelete');
            var originalText = btn.innerText;
            btn.innerText = 'กำลังลบ...';
            btn.disabled = true;

            fetch('/api/delete_rows', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    id: currentEditId,
                    productCodes: pendingDeletes
                })
            })
            .then(function(response) { return response.json(); })
            .then(function(data) {
                if (data.error) {
                    alert('เกิดข้อผิดพลาด: ' + data.error);
                    btn.innerText = originalText;
                    btn.disabled = false;
                    return;
                }
                alert('ลบสำเร็จ ' + data.deleted + ' รายการ');
                pendingDeletes = [];
                window.location.reload();
            })
            .catch(function(err) {
                console.error('Delete error:', err);
                alert('เกิดข้อผิดพลาด: ' + err.message);
                btn.innerText = originalText;
                btn.disabled = false;
            });
        }
    </script>
</body>

</html>