<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Kanit:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&family=Sarabun:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800&display=swap"
    rel="stylesheet">
  <link rel="stylesheet" href="menubar.css">
  <link rel="stylesheet" href="sale_pr.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

  <title>รายการเสนอขาย (PR) - ERP System</title>
</head>

<body>

  <aside class="sidebar">
    <div class="logo">
      <h2>ระบบ ERP</h2>
      <span>ระดับจงกร</span><br>
    </div>

    <nav class="menu">
      <a href="<%= baseUrl %>/">Dashboard</a>
      <a href="<%= baseUrl %>/add_sale">เพิ่มออเดอร์</a>
      <a href="<%= baseUrl %>/sale_pr" class="active">เสนอขาย</a>
      <a href="<%= baseUrl %>/sale_so">Sale SO</a>
      <a href="#">เสนอซื้อ</a>
      <a href="<%= baseUrl %>/inventory">คลังสินค้า</a>
      <a href="<%= baseUrl %>/ai_chat"> AI Assistant</a>
    </nav>

    <div style="margin-top: auto; padding: 20px 0; text-align: center; border-top: 1px solid rgba(255,255,255,0.1);">
      <div style="color: #a0a0b5; margin-bottom: 10px; font-size: 0.9rem;">
        <i class="fas fa-user-circle"></i>
        <%= (typeof user !=='undefined' && user) ? user['ชื่อpic'] : 'Unknown' %>
      </div>
      <a href="<%= baseUrl %>/logout" class="btn-logout">
        <i class="fas fa-sign-out-alt"></i> ออกจากระบบ
      </a>
    </div>
  </aside>

  <main style="padding: 20px;">
    <h1 style="color: #ff7eb3; margin-bottom: 25px;">
        <i class="fas fa-file-invoice-dollar"></i> รายการเสนอขาย (PR)
    </h1>

    <div class="status-tabs">
      <a href="/sale_pr?status=ทั้งหมด&search=<%= search %>" class="status-tab <%= currentStatus === 'ทั้งหมด' ? 'active' : '' %>">
        ทั้งหมด
      </a>
      <a href="/sale_pr?status=ยังไม่ยืนยัน&search=<%= search %>" class="status-tab <%= currentStatus === 'ยังไม่ยืนยัน' ? 'active' : '' %>">
        <i class="fas fa-clock"></i> ยังไม่ยืนยัน
      </a>
      <a href="/sale_pr?status=ยืนยันแล้ว&search=<%= search %>" class="status-tab <%= currentStatus === 'ยืนยันแล้ว' ? 'active' : '' %>">
        <i class="fas fa-check-circle"></i> ยืนยันแล้ว
      </a>
    </div>

    <form action="/sale_pr" method="GET" class="search-container">
      <input type="hidden" name="status" value="<%= currentStatus %>">
      <input type="text" name="search" class="search-input" value="<%= search %>" placeholder="ค้นหาด้วยชื่อลูกค้า หรือ ID...">

      <button type="submit" class="btn-search">
        <i class="fas fa-search"></i> ค้นหา
      </button>

      <a href="/sale_pr" class="btn-clear">
        <i class="fas fa-sync-alt"></i> ล้างค่า
      </a>
    </form>


    <div class="table-responsive" style="overflow-x: auto; width: 100%;">
      <table>
        <thead>
          <tr>
            <% if (data && data.length> 0) { %>
              <% Object.keys(data[0]).forEach(h=> { %>
                <th>
                  <%= h %>
                </th>
                <% }) %>
                  <th style="text-align: center;">จัดการ</th>
                  <th style="text-align: center;">ยืนยัน</th>
                  <th style="text-align: center;">ลบ</th>
                  <% } %>
          </tr>
        </thead>
        <tbody>
          <% if (data && data.length> 0) { %>
            <% data.forEach(row=> { %>
              <tr>
                <% Object.entries(row).forEach(([key, val])=> { %>
                  <td>
                    <% if (key === 'สถานะเอกสาร') { %>
                      <span class="status-badge <%= val === 'ยืนยันแล้ว' ? 'status-success' : 'status-pending' %>">
                        <%= val %>
                      </span>
                    <% } else { %>
                      <%= val %>
                    <% } %>
                  </td>
                  <% }) %>

                    <td style="text-align: center;">
                      <a href="/edit_sale?id=<%= row['id'] %>" class="action-btn edit-btn">
                        <i class="fas fa-pencil"></i>
                      </a>
                    </td>
                    <td style="text-align: center;">
                      <% if (row['สถานะเอกสาร'] !== 'ยืนยันแล้ว') { %>
                        <a href="javascript:void(0);" onclick="confirmSendWebhook(this, '<%= row['id'] %>')"
                          class="action-btn confirm-btn">
                          <i class="fas fa-paper-plane"></i>
                        </a>
                      <% } else { %>
                        <span class="action-btn" style="color: #666; cursor: not-allowed; opacity: 0.5;">
                          <i class="fas fa-check-double"></i>
                        </span>
                      <% } %>
                    </td>
                    <td style="text-align: center;">
                      <a href="javascript:void(0);" onclick="deleteSale('<%= row['id'] %>')" class="action-btn delete-btn">
                        <i class="fa-solid fa-trash"></i>
                      </a>
                    </td>
              </tr>
              <% }) } else { %>
                <tr>
                  <td colspan="100%" style="text-align: center; padding: 50px; font-style: italic; color: #666;">
                    ไม่มีรายการในกลุ่มนี้
                  </td>
                </tr>
                <% } %>
        </tbody>
      </table>
    </div>
  </main>

  <script>
    async function confirmSendWebhook(element, id) {
      const result = await Swal.fire({
        title: 'ยืนยันการส่งข้อมูล?',
        text: `ยืนยันที่จะส่งข้อมูล ID: ${id} ไปยัง Webhook ใช่หรือไม่?`,
        icon: 'question',
        showCancelButton: true,
        confirmButtonColor: '#ff7eb3',
        cancelButtonColor: '#281a3d',
        confirmButtonText: 'ยืนยันส่งข้อมูล',
        cancelButtonText: 'ยกเลิก',
        background: '#1d112e',
        color: '#fff'
      });

      if (!result.isConfirmed) return;

      Swal.fire({
        title: 'กำลังส่งข้อมูล...',
        allowOutsideClick: false,
        didOpen: () => {
          Swal.showLoading();
        },
        background: '#1d112e',
        color: '#fff'
      });

      try {
        const response = await fetch('/api/confirm-webhook', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: id })
        });

        const result = await response.json();

        if (response.ok && result.success) {
          Swal.fire({
            icon: 'success',
            title: 'ส่งข้อมูลสำเร็จ',
            text: 'ระบบได้ทำการส่งข้อมูลและปรับปรุงสถานะเรียบร้อยแล้ว',
            background: '#1d112e',
            color: '#fff',
            confirmButtonColor: '#ff7eb3'
          }).then(() => {
            window.location.reload();
          });
        } else {
          Swal.fire({
            icon: 'error',
            title: 'เกิดข้อผิดพลาด',
            text: result.error || 'ไม่สามารถส่งข้อมูลได้',
            background: '#1d112e',
            color: '#fff'
          });
        }
      } catch (err) {
        console.error('Error:', err);
        Swal.fire({
          icon: 'error',
          title: 'ผิดพลาด',
          text: 'เกิดข้อผิดพลาดในการเชื่อมต่อกับเซิร์ฟเวอร์',
          background: '#1d112e',
          color: '#fff'
        });
      }
    }

    function deleteSale(id) {
        Swal.fire({
            title: 'ยืนยันการลบ?',
            text: `คุณแน่ใจนะว่าต้องการลบรายการ ID: ${id}?`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#dc3545',
            cancelButtonColor: '#281a3d',
            confirmButtonText: 'ใช่, ลบเลย!',
            cancelButtonText: 'ยกเลิก',
            background: '#1d112e',
            color: '#fff'
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = `/delsale?id=${id}`;
            }
        });
    }

    document.querySelector('.search-container').addEventListener('submit', function (e) {
      const btn = this.querySelector('.btn-search');
      btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> กำลังค้นหา...';
      btn.disabled = true;
    });
  </script>

</body>

</html>