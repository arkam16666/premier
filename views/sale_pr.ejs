<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Kanit:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&family=Sarabun:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800&display=swap"
    rel="stylesheet">
  <link rel="stylesheet" href="menubar.css">
  <link rel="stylesheet" href="sale_pr.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

  <title>ERP System</title>
</head>

<body>

  <aside class="sidebar">
    <div class="logo">
      <h2>ระบบ ERP</h2>
      <span>ระดับจงกร</span><br>
    </div>

    <nav class="menu">
      <a href="<%= baseUrl %>/" class="active">Dashboard</a>
      <a href="<%= baseUrl %>/sale_pr" class="buy">เสนอซื้อ</a>
      <a href="#">เสนอขาย</a>
      <a href="#">คลังสินค้า</a>
    </nav>
  </aside>

  <main style="padding: 20px;">
    <form action="/sale_pr" method="GET" class="search-container">
      <input type="text" name="search" class="search-input" value="<%= search %>" placeholder="ค้นหาด้วย ID">

      <button type="submit" class="btn-search">
        <i class="fas fa-search"></i> ค้นหา
      </button>

      <a href="/sale_pr" class="btn-clear">
        <i class="fas fa-sync-alt"></i> ล้างค่า
      </a>
    </form>


    <div class="table-responsive" style="overflow-x: auto; width: 100%;">
      <table>
        <thead>
          <tr>
            <% if (data && data.length> 0) { %>
              <% Object.keys(data[0]).forEach(h=> { %>
                <th>
                  <%= h %>
                </th>
                <% }) %>

                  <th style="text-align: center;">จัดการ</th>
                  <th style="text-align: center;">ลบ</th>
                  <% } %>
          </tr>
        </thead>
        <tbody>
          <% if (data && data.length> 0) { %>
            <% data.forEach(row=> { %>
              <tr>
                <% Object.values(row).forEach(val=> { %>
                  <td>
                    <%= val %>
                  </td>
                  <% }) %>

                    <td style="text-align: center;">
                      <a href="/edit_sale?id=<%= row['id'] %>">
                        <i class="fas fa-pencil"></i>
                      </a>
                    </td>

                    <td style="text-align: center;">
                      <a href="/delsale?id=<%= row['id'] %>" 
                         class="delete-btn"
                         onclick="return handleDelete(this, '<%= row['id'] %>')">
                        <i class="fa-solid fa-trash"></i>
                      </a>
                    </td>
              </tr>
              <% }) } else { %>
                <tr>
                  <td colspan="100%" style="text-align: center;">ไม่มีข้อมูล</td>
                </tr>
                <% } %>
        </tbody>
      </table>
    </div>
  </main>

  <script>
    function handleDelete(link, id) {
      if (confirm('คุณแน่ใจหรือไม่ที่จะลบข้อมูล ID: ' + id + '?')) {
        link.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
        link.style.pointerEvents = 'none';
        return true; // Proceed to href
      }
      return false;
    }

    document.querySelector('.search-container').addEventListener('submit', function(e) {
      const btn = this.querySelector('.btn-search');
      btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> กำลังค้นหา...';
      btn.disabled = true;
    });
  </script>
</body>

</html>