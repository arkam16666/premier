<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Kanit:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&family=Sarabun:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="menubar.css">
    <link rel="stylesheet" href="style.css">
    <link rel="stylesheet" href="ai_chat.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.8.0/styles/github-dark.min.css">
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.8.0/highlight.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <title>AI Assistant - ERP System</title>
</head>

<body>
    <div class="container">
        <aside class="sidebar">
            <div class="logo">
                <h2>ระบบ ERP</h2>
                <span>ระดับจัดการ</span><br>
            </div>

            <nav class="menu">
                <a href="<%= baseUrl %>/">Dashboard</a>
                <a href="<%= baseUrl %>/add_sale">เพิ่มออเดอร์</a>
                <a href="<%= baseUrl %>/sale_pr">เสนอขาย</a>
                <a href="<%= baseUrl %>/sale_so">Sale SO</a>
                <a href="#">เสนอซื้อ</a>
                <a href="<%= baseUrl %>/inventory">คลังสินค้า</a>
                <a href="<%= baseUrl %>/ai_chat" class="active"> AI Assistant</a>
            </nav>

            <div style="margin-top: auto; padding: 20px 0; text-align: center; border-top: 1px solid rgba(255,255,255,0.1);">
                <div style="color: #a0a0b5; margin-bottom: 10px; font-size: 0.9rem;">
                    <i class="fas fa-user-circle"></i>
                    <%= (typeof user !=='undefined' && user) ? user['ชื่อpic'] : 'Unknown' %>
                </div>
                <a href="<%= baseUrl %>/logout" class="btn-logout">
                    <i class="fas fa-sign-out-alt"></i> ออกจากระบบ
                </a>
            </div>
        </aside>

        <main class="main-content">
            <header class="animate-up">
                <h1 style="font-size: 2.2rem; color: #fff;"> AI Assistant</h1>
                <p style="color: #a0a0b5; margin-top: 5px;">คุยกับ "พี่ AI" เพื่อเช็คข้อมูลในระบบได้เลยครับ</p>
            </header>

            <div class="chat-container">
                <div class="chat-header">
                    <div class="chat-status">
                        <div class="status-dot"></div>
                        <span>Pee AI Online | Ready to Help</span>
                    </div>
                    <div class="model-selector-wrapper">
                        <i class="fas fa-microchip" style="color: #a786ff; margin-right: 5px;"></i>
                        <select id="modelSelector" class="model-select">
                            <option value="gemini-3.1-flash-lite">Gemini 1.5 Flash (Default)</option>
                        </select>
                    </div>
                    <button id="clearChatBtn" class="btn-clear" title="ล้างประวัติการแชท">
                        <i class="fas fa-trash-alt"></i> ล้างแชท
                    </button>
                </div>

                <div class="chat-messages" id="chatMessages">
                    <% if (history && history.length > 0) { %>
                        <% history.forEach(msg => { %>
                            <div class="message <%= msg.role === 'user' ? 'user' : 'ai' %>">
                                <div class="message-header">
                                    <i class="fas <%= msg.role === 'user' ? 'fa-user' : '' %>"></i>
                                    <%= msg.role === 'user' ? 'You' : 'พี่ AI Assistant' %>
                                </div>
                                <div class="message-content" data-raw="<%= msg.text %>">
                                    <% if (msg.role === 'model') { %>
                                        <%- msg.text %>
                                    <% } else { %>
                                        <%= msg.text %>
                                    <% } %>
                                </div>
                                <% if (msg.role === 'model') { %>
                                    <div class="rag-badge"><i class="fas fa-database"></i> Database Connected</div>
                                <% } %>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <div class="message ai">
                            <div class="message-header"> พี่ AI Assistant</div>
                            <div class="message-content">
                                สวัสดีครับน้อง! พี่เป็นผู้ช่วยประจำระบบ ERP พรีเมียร์นะครับ อยากให้พี่ช่วยเช็คสต็อกสินค้า สรุปยอดขาย หรือหาข้อมูลตรงไหน บอกพี่ได้เลยนะ พี่สแตนบายรอช่วยอยู่ครับ! 😊
                            </div>
                        </div>
                    <% } %>
                </div>

                <div class="chat-input-area">
                    <input type="text" id="chatInput" class="chat-input" placeholder="พิมพ์คุยกับพี่ AI ได้ที่นี่เลย..." autocomplete="off">
                    <button id="sendBtn" class="btn-send">
                        <i class="fas fa-paper-plane"></i>
                    </button>
                </div>
            </div>
        </main>
    </div>

    <script>
        const chatMessages = document.getElementById('chatMessages');
        const chatInput = document.getElementById('chatInput');
        const sendBtn = document.getElementById('sendBtn');
        const modelSelector = document.getElementById('modelSelector');

        // Fetch available models
        async function fetchModels() {
            try {
                const response = await fetch('/api/models');
                if (response.ok) {
                    const data = await response.json();
                    
                    // Clear existing options (except the first one if we want to keep it as default)
                    modelSelector.innerHTML = '';
                    
                    // Add Gemini models
                    if (data.gemini && data.gemini.length > 0) {
                        const geminiGroup = document.createElement('optgroup');
                        geminiGroup.label = 'Google Gemini';
                        data.gemini.forEach(m => {
                            const option = document.createElement('option');
                            option.value = m.id;
                            option.textContent = m.name;
                            geminiGroup.appendChild(option);
                        });
                        modelSelector.appendChild(geminiGroup);
                    }
                    
                    // Add Ollama models
                    if (data.ollama && data.ollama.length > 0) {
                        const ollamaGroup = document.createElement('optgroup');
                        ollamaGroup.label = 'Ollama (Local)';
                        data.ollama.forEach(m => {
                            const option = document.createElement('option');
                            option.value = m.id;
                            option.textContent = m.name;
                            ollamaGroup.appendChild(option);
                        });
                        modelSelector.appendChild(ollamaGroup);
                    }
                }
            } catch (err) {
                console.error('Error fetching models:', err);
            }
        }

        // Configure SweetAlert2 globally
        const Toast = Swal.mixin({
            toast: true,
            position: 'top-end',
            showConfirmButton: false,
            timer: 3000,
            timerProgressBar: true,
            background: '#1d112e',
            color: '#e0e0e0',
            didOpen: (toast) => {
                toast.addEventListener('mouseenter', Swal.stopTimer)
                toast.addEventListener('mouseleave', Swal.resumeTimer)
            }
        });

        // Configure marked with highlight.js
        const renderer = new marked.Renderer();
        
        // Custom link renderer to open in new tab
        renderer.link = (href, title, text) => {
            return `<a href="${href}" title="${title || ''}" target="_blank" rel="noopener noreferrer">${text}</a>`;
        };

        marked.setOptions({
            renderer: renderer,
            highlight: function(code, lang) {
                const language = hljs.getLanguage(lang) ? lang : 'plaintext';
                return hljs.highlight(code, { language }).value;
            },
            langPrefix: 'hljs language-',
            breaks: true,
            gfm: true
        });

        function copyCode(btn, code) {
            navigator.clipboard.writeText(code).then(() => {
                const originalText = btn.innerText;
                btn.innerText = 'คัดลอกแล้ว!';
                btn.style.background = '#28a745';
                setTimeout(() => {
                    btn.innerText = originalText;
                    btn.style.background = '';
                }, 2000);
                Toast.fire({
                    icon: 'success',
                    title: 'คัดลอกรหัสเรียบร้อย!'
                });
            });
        }

        function enrichAIContent(container) {
            // Add copy buttons to pre tags
            container.querySelectorAll('pre').forEach(pre => {
                const code = pre.querySelector('code').innerText;
                const copyBtn = document.createElement('button');
                copyBtn.className = 'copy-code-btn';
                copyBtn.innerHTML = '<i class="far fa-copy"></i> Copy';
                copyBtn.onclick = () => copyCode(copyBtn, code);
                pre.appendChild(copyBtn);
            });
        }

        function addMessage(text, isAi = false) {
            const msgDiv = document.createElement('div');
            msgDiv.className = `message ${isAi ? 'ai' : 'user'}`;
            
            const header = document.createElement('div');
            header.className = 'message-header';
            header.innerHTML = isAi ? ' พี่ AI Assistant' : '<i class="fas fa-user"></i> You';
            
            const content = document.createElement('div');
            content.className = 'message-content';
            
            if (isAi) {
                // Use marked for AI response to support bold, lists, etc.
                content.innerHTML = marked.parse(text);
                
                const ragBadge = document.createElement('div');
                ragBadge.className = 'rag-badge';
                ragBadge.innerHTML = '<i class="fas fa-database"></i> Database Connected';
                
                msgDiv.appendChild(header);
                msgDiv.appendChild(ragBadge);
                msgDiv.appendChild(content);
                
                enrichAIContent(content);
            } else {
                content.innerText = text;
                msgDiv.appendChild(header);
                msgDiv.appendChild(content);
            }
            
            chatMessages.appendChild(msgDiv);
            chatMessages.scrollTop = chatMessages.scrollHeight;
        }

        // Initialize history messages
        window.addEventListener('DOMContentLoaded', () => {
            fetchModels();
            document.querySelectorAll('.message.ai .message-content').forEach(content => {
                const rawText = content.getAttribute('data-raw');
                if (rawText) {
                    content.innerHTML = marked.parse(rawText);
                    enrichAIContent(content);
                }
            });
            chatMessages.scrollTop = chatMessages.scrollHeight;
        });

        function showTypingIndicator() {
            const indicator = document.createElement('div');
            indicator.className = 'message ai typing-indicator-wrapper';
            indicator.id = 'typingIndicator';
            indicator.innerHTML = `
                <div class="message-header"> พี่ AI Assistant</div>
                <div class="typing-indicator">
                    <div class="dot"></div>
                    <div class="dot"></div>
                    <div class="dot"></div>
                </div>
            `;
            chatMessages.appendChild(indicator);
            chatMessages.scrollTop = chatMessages.scrollHeight;
        }

        function removeTypingIndicator() {
            const indicator = document.getElementById('typingIndicator');
            if (indicator) indicator.remove();
        }

        async function sendMessage() {
            const text = chatInput.value.trim();
            const selectedModel = modelSelector.value;
            if (!text) return;

            addMessage(text, false);
            chatInput.value = '';
            chatInput.disabled = true;
            sendBtn.disabled = true;

            showTypingIndicator();

            try {
                const response = await fetch('/api/chat', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ 
                        message: text,
                        model: selectedModel
                    })
                });

                const result = await response.json();
                removeTypingIndicator();

                if (response.ok && result.response) {
                    addMessage(result.response, true);
                } else {
                    addMessage('ขออภัยครับ เกิดข้อผิดพลาดในการประมวลผล: ' + (result.error || 'Unknown error'), true);
                    Swal.fire({
                        icon: 'error',
                        title: 'เกิดข้อผิดพลาด',
                        text: result.error || 'Unknown error',
                        background: '#1d112e',
                        color: '#e0e0e0',
                        confirmButtonColor: '#ff7eb3'
                    });
                }
            } catch (err) {
                console.error('Chat error:', err);
                removeTypingIndicator();
                addMessage('ขออภัยครับ ไม่สามารถเชื่อมต่อกับเซิร์ฟเวอร์ได้', true);
                Toast.fire({
                    icon: 'error',
                    title: 'เชื่อมต่อเซิร์ฟเวอร์ไม่ได้'
                });
            } finally {
                chatInput.disabled = false;
                sendBtn.disabled = false;
                chatInput.focus();
            }
        }

        sendBtn.addEventListener('click', sendMessage);
        chatInput.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') sendMessage();
        });

        // Clear Chat History
        document.getElementById('clearChatBtn').addEventListener('click', async () => {
            const result = await Swal.fire({
                title: 'ยืนยันการล้างแชท?',
                text: "น้องแน่ใจนะครับว่าต้องการล้างประวัติการแชททั้งหมด?",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ff2d88',
                cancelButtonColor: '#281a3d',
                confirmButtonText: 'ล้างเลย!',
                cancelButtonText: 'ยกเลิก',
                background: '#1d112e',
                color: '#e0e0e0'
            });

            if (result.isConfirmed) {
                try {
                    const response = await fetch('/api/chat/clear', { method: 'POST' });
                    if (response.ok) {
                        chatMessages.innerHTML = `
                            <div class="message ai">
                                <div class="message-header"> พี่ AI Assistant</div>
                                <div class="message-content">
                                    พี่ล้างประวัติการแชทให้เรียบร้อยแล้วครับ! มีอะไรให้พี่ช่วยใหม่ บอกได้เลยนะ 😊
                                </div>
                            </div>
                        `;
                        Toast.fire({
                            icon: 'success',
                            title: 'ล้างแชทสำเร็จ'
                        });
                    }
                } catch (err) {
                    console.error('Clear chat error:', err);
                    Swal.fire({
                        icon: 'error',
                        title: 'ผิดพลาด',
                        text: 'เกิดข้อผิดพลาดในการล้างแชทครับ',
                        background: '#1d112e',
                        color: '#e0e0e0'
                    });
                }
            }
        });
    </script>
</body>


</html>
