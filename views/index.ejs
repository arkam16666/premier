<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Kanit:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&family=Sarabun:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="style.css">
    <link rel="stylesheet" href="menubar.css">
    <link rel="stylesheet" href="ai_widget.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <title>ERP Dashboard | ระบบจัดการ</title>
</head>

<body>
    <div class="container">
        <aside class="sidebar">
            <div class="logo">
                <h2>ระบบ ERP</h2>
                <span>ระดับจัดการ</span><br>
            </div>

            <nav class="menu">
                <a href="<%= baseUrl %>/" class="active"><i class="icon-dashboard"></i> Dashboard</a>
                <a href="<%= baseUrl %>/add_sale">เพิ่มออเดอร์</a>
                <a href="<%= baseUrl %>/sale_pr"><i class="icon-sales"></i> เสนอขาย</a>
                <a href="<%= baseUrl %>/sale_so">Sale SO</a>
                <a href="#"><i class="icon-inventory"></i> เสนอซื้อ</a>
                <a href="<%= baseUrl %>/inventory">คลังสินค้า</a>
                <a href="<%= baseUrl %>/ai_chat"><i class="fas fa-robot"></i> AI Assistant</a>
            </nav>

            <div
                style="margin-top: auto; padding: 20px 0; text-align: center; border-top: 1px solid rgba(255,255,255,0.1);">
                <div style="color: #a0a0b5; margin-bottom: 10px; font-size: 0.9rem;">
                    <i class="fas fa-user-circle"></i>
                    <%= (typeof user !=='undefined' && user) ? user['ชื่อpic'] : 'Unknown' %>
                </div>
                <a href="<%= baseUrl %>/logout" class="btn-logout">
                    <i class="fas fa-sign-out-alt"></i> ออกจากระบบ
                </a>
            </div>
        </aside>

        <main class="main-content">
            <header style="margin-bottom: 40px;" class="animate-up">
                <h1 style="font-size: 2.2rem; color: #fff;">ยินดีต้อนรับ, <%= (typeof user !=='undefined' && user) ? user['ชื่อpic'] : 'Guest' %></h1>
                <p style="color: #a0a0b5; margin-top: 5px;">นี่คือภาพรวมของระบบ ERP ของคุณในวันนี้</p>
            </header>

            <div class="stats-grid">
                <div class="stat-card card-revenue animate-up delay-1">
                    <div class="stat-icon"><i class="fas fa-coins"></i></div>
                    <div class="stat-label">ยอดขายรวมทั้งหมด (SO)</div>
                    <div class="stat-value">฿<%= stats.totalRevenue %></div>
                </div>

                <div class="stat-card card-pending animate-up delay-2">
                    <div class="stat-icon"><i class="fas fa-clock"></i></div>
                    <div class="stat-label">ออเดอร์รอการยืนยัน</div>
                    <div class="stat-value"><%= stats.pendingOrders %> รายการ</div>
                </div>

                <div class="stat-card card-stock animate-up delay-3">
                    <div class="stat-icon"><i class="fas fa-exclamation-triangle"></i></div>
                    <div class="stat-label">สินค้าสต็อกต่ำ (< 10)</div>
                    <div class="stat-value"><%= stats.lowStockCount %> รายการ</div>
                </div>

                <div class="stat-card card-products animate-up delay-4">
                    <div class="stat-icon"><i class="fas fa-box-open"></i></div>
                    <div class="stat-label">จำนวนสินค้าทั้งหมด</div>
                    <div class="stat-value"><%= stats.totalProducts %> SKUs</div>
                </div>
            </div>

            <!-- Chart Section -->
            <div class="dashboard-row animate-up delay-5" style="margin-bottom: 25px; grid-template-columns: 1.5fr 1fr;">
                <div class="glass-panel">
                    <div class="panel-header">
                        <h2 class="panel-title"><i class="fas fa-chart-area"></i> แนวโน้มยอดขายรายเดือน</h2>
                    </div>
                    <div style="height: 300px; position: relative;">
                        <canvas id="salesChart"></canvas>
                    </div>
                </div>
                <div class="glass-panel">
                    <div class="panel-header">
                        <h2 class="panel-title"><i class="fas fa-chart-pie"></i> สัดส่วนสถานะเอกสาร</h2>
                    </div>
                    <div style="height: 300px; position: relative; display: flex; justify-content: center;">
                        <canvas id="statusChart"></canvas>
                    </div>
                </div>
            </div>

            <div class="dashboard-row animate-up delay-5">
                <div class="glass-panel">
                    <div class="panel-header">
                        <h2 class="panel-title"><i class="fas fa-history"></i> รายการเสนอขายล่าสุด</h2>
                        <a href="/sale_pr" style="color: #a786ff; text-decoration: none; font-size: 0.9rem;">ดูทั้งหมด</a>
                    </div>
                    <table class="recent-table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>วันที่</th>
                                <th>ลูกค้า</th>
                                <th>PIC</th>
                                <th>สถานะ</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (recentSales && recentSales.length > 0) { %>
                                <% recentSales.forEach(sale => { 
                                    const isConfirmed = ['สำเร็จ', 'ยืนยันแล้ว'].includes((sale['สถานะเอกสาร'] || '').trim());
                                %>
                                    <tr>
                                        <td>#<%= sale['id'] %></td>
                                        <td><%= sale['วันที่'] %></td>
                                        <td><%= sale['ลูกค้า-ผู้ขาย'] %></td>
                                        <td><%= sale['PIC'] %></td>
                                        <td>
                                            <span class="status-indicator <%= isConfirmed ? 'status-confirmed' : 'status-pending' %>">
                                                <%= isConfirmed ? 'ยืนยันแล้ว' : 'รอการยืนยัน' %>
                                            </span>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="5" style="text-align: center; color: #666; padding: 30px;">ไม่มีข้อมูลรายการล่าสุด</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>

                <div class="glass-panel" style="display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; background: #150c22; border: 1px solid #281a3d;">
                    <div style="font-size: 3rem; color: #ff7eb3; margin-bottom: 20px;"><i class="fas fa-plus-circle"></i></div>
                    <h3 style="margin-bottom: 15px;">เพิ่มรายการใหม่</h3>
                    <p style="color: #a0a0b5; font-size: 0.9rem; margin-bottom: 25px;">เริ่มการขายใหม่หรือเช็คคลังสินค้าได้ทันทีจากที่นี่</p>
                    <div style="display: flex; flex-direction: column; gap: 10px; width: 100%;">
                        <a href="/add_sale" style="text-decoration: none;">
                            <div style="background: linear-gradient(135deg, rgba(255, 126, 179, 0.8), rgba(255, 45, 136, 0.8)); padding: 12px; border-radius: 8px; color: white; font-weight: 600; border: 1px solid rgba(255, 126, 179, 0.3);">
                                <i class="fas fa-plus"></i> ออกใบเสนอขาย
                            </div>
                        </a>
                        <a href="/inventory" style="text-decoration: none;">
                            <div style="background: rgba(255,255,255,0.05); padding: 12px; border-radius: 8px; color: white; border: 1px solid rgba(255,255,255,0.1);">
                                <i class="fas fa-boxes"></i> เช็กสต็อกสินค้า
                            </div>
                        </a>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- Floating AI Button -->
    <a href="/ai_chat" class="floating-ai-btn animate-up" title="ถาม AI ผู้ช่วย">
        <i class="fas fa-robot"></i>
        <span class="pulse"></span>
    </a>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Data from Server
        const chartData = <%- JSON.stringify(chartData) %>;

        // Common Chart Options for Dark Theme
        const commonOptions = {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: {
                    labels: { color: '#a0a0b5', font: { family: 'Kanit' } }
                }
            }
        };

        // 1. Sales Trend Chart (Line)
        const ctxSales = document.getElementById('salesChart').getContext('2d');
        const salesGradient = ctxSales.createLinearGradient(0, 0, 0, 400);
        salesGradient.addColorStop(0, 'rgba(167, 134, 255, 0.25)');
        salesGradient.addColorStop(1, 'rgba(167, 134, 255, 0)');

        new Chart(ctxSales, {
            type: 'line',
            data: {
                labels: chartData.labels,
                datasets: [{
                    label: 'ยอดขาย (บาท)',
                    data: chartData.sales,
                    borderColor: '#a786ff',
                    backgroundColor: salesGradient,
                    fill: true,
                    tension: 0.4,
                    borderWidth: 2,
                    pointBackgroundColor: '#fff',
                    pointRadius: 3
                }]
            },
            options: {
                ...commonOptions,
                scales: {
                    y: {
                        beginAtZero: true,
                        grid: { color: 'rgba(255, 255, 255, 0.05)' },
                        ticks: { color: '#a0a0b5' }
                    },
                    x: {
                        grid: { display: false },
                        ticks: { color: '#a0a0b5' }
                    }
                }
            }
        });

        // 2. Status Distribution Chart (Doughnut)
        const ctxStatus = document.getElementById('statusChart').getContext('2d');
        new Chart(ctxStatus, {
            type: 'doughnut',
            data: {
                labels: ['ยืนยันแล้ว', 'รอการยืนยัน'],
                datasets: [{
                    data: chartData.status,
                    backgroundColor: [
                        'rgba(255, 126, 179, 0.8)', // Subdued Pink
                        'rgba(255, 202, 44, 0.8)'   // Subdued Amber
                    ],
                    borderWidth: 1,
                    borderColor: '#150c22',
                    hoverOffset: 5
                }]
            },
            options: {
                ...commonOptions,
                cutout: '75%',
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: { padding: 20, color: '#a0a0b5' }
                    }
                }
            }
        });
    </script>
</body>

</html>