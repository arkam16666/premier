<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Kanit:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&family=Sarabun:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800&display=swap"
    rel="stylesheet">
  <link rel="stylesheet" href="menubar.css">
  <link rel="stylesheet" href="sale_so.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

  <title>Sale SO - ERP System</title>
</head>

<body>

  <aside class="sidebar">
    <div class="logo">
      <h2>ระบบ ERP</h2>
      <span>ระดับจงกร</span><br>
    </div>

    <nav class="menu">
      <a href="<%= baseUrl %>/">Dashboard</a>
      <a href="<%= baseUrl %>/add_sale">เพิ่มออเดอร์</a>
      <a href="<%= baseUrl %>/sale_pr">เสนอขาย</a>
      <a href="<%= baseUrl %>/sale_so" class="active">Sale SO</a>
      <a href="#">เสนอซื้อ</a>
      <a href="<%= baseUrl %>/inventory">คลังสินค้า</a>
      <a href="<%= baseUrl %>/ai_chat"> AI Assistant</a>
    </nav>

    <div style="margin-top: auto; padding: 20px 0; text-align: center; border-top: 1px solid rgba(255,255,255,0.1);">
      <div style="color: #a0a0b5; margin-bottom: 10px; font-size: 0.9rem;">
        <i class="fas fa-user-circle"></i>
        <%= (typeof user !=='undefined' && user) ? user['ชื่อpic'] : 'Unknown' %>
      </div>
      <a href="<%= baseUrl %>/logout" class="btn-logout">
        <i class="fas fa-sign-out-alt"></i> ออกจากระบบ
      </a>
    </div>
  </aside>

  <main style="padding: 20px;">
    <h1 style="color: #ff7eb3; margin-bottom: 25px;">
        <i class="fas fa-file-contract"></i> รายการสั่งขาย (Sale SO)
    </h1>

    <form action="/sale_so" method="GET" class="search-container">
      <input type="text" name="search" class="search-input" value="<%= search %>" placeholder="ค้นหาด้วย ID ใน Sale SO">

      <button type="submit" class="btn-search">
        <i class="fas fa-search"></i> ค้นหา
      </button>

      <a href="/sale_so" class="btn-clear">
        <i class="fas fa-sync-alt"></i> ล้างค่า
      </a>
    </form>


    <div class="table-responsive" style="overflow-x: auto; width: 100%;">
      <table>
        <thead>
          <tr>
            <% if (data && data.length> 0) { %>
              <% Object.keys(data[0]).forEach(h=> { %>
                <th>
                  <%= h %>
                </th>
                <% }) %>
                  <th style="text-align: center;">จัดการ</th>
                  <th style="text-align: center;">ลบ</th>
                  <% } %>
          </tr>
        </thead>
        <tbody>
          <% if (data && data.length> 0) { %>
            <% data.forEach(row=> { %>
              <tr>
                <% Object.entries(row).forEach(([key, val])=> { %>
                  <td>
                    <% if (key === 'สถานะเอกสาร') { %>
                      <span class="status-badge <%= val === 'สำเร็จ' || val === 'ยืนยันแล้ว' ? 'status-success' : 'status-pending' %>">
                        <%= val === 'สำเร็จ' ? 'ยืนยันแล้ว' : (val || 'รอดำเนินการ') %>
                      </span>
                    <% } else { %>
                      <%= val %>
                    <% } %>
                  </td>
                  <% }) %>

                    <td style="text-align: center;">
                      <a href="/edit_sale_so?id=<%= row['id'] %>" class="action-btn edit-btn">
                        <i class="fas fa-pencil"></i>
                      </a>
                    </td>
                    <td style="text-align: center;">
                      <a href="javascript:void(0);" onclick="deleteItem(this, '<%= row['id'] %>')" class="action-btn delete-btn">
                        <i class="fa-solid fa-trash"></i>
                      </a>
                    </td>
              </tr>
              <% }) } else { %>
                <tr>
                  <td colspan="100%" style="text-align: center; padding: 50px; font-style: italic; color: #666;">
                    ไม่มีข้อมูลในระบบ Sale SO
                  </td>
                </tr>
                <% } %>
        </tbody>
      </table>
    </div>
  </main>

  <script>
    async function deleteItem(element, id) {
      const result = await Swal.fire({
        title: 'ยืนยันการลบ?',
        text: `ยืนยันการลบรายการ ID: ${id} ใช่หรือไม่?`,
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#dc3545',
        cancelButtonColor: '#281a3d',
        confirmButtonText: 'ใช่, ลบเลย!',
        cancelButtonText: 'ยกเลิก',
        background: '#1d112e',
        color: '#fff'
      });

      if (!result.isConfirmed) return;

      // Show loading
      Swal.fire({
        title: 'กำลังประมวลผล...',
        allowOutsideClick: false,
        didOpen: () => {
          Swal.showLoading();
        },
        background: '#1d112e',
        color: '#fff'
      });

      try {
        const response = await fetch(`/api/delete_order_so?id=${id}`, { method: 'POST' });
        const result = await response.json();

        if (response.ok && result.success) {
          Swal.fire({
            icon: 'success',
            title: 'ลบข้อมูลเรียบร้อยแล้ว',
            background: '#1d112e',
            color: '#fff',
            confirmButtonColor: '#ff7eb3',
            timer: 1500,
            showConfirmButton: false
          }).then(() => {
            window.location.reload();
          });
        } else {
          Swal.fire({
            icon: 'error',
            title: 'เกิดข้อผิดพลาด',
            text: result.error || 'ไม่สามารถลบข้อมูลได้',
            background: '#1d112e',
            color: '#fff'
          });
        }
      } catch (err) {
        console.error('Delete error:', err);
        Swal.fire({
          icon: 'error',
          title: 'ผิดพลาด',
          text: 'เกิดข้อผิดพลาดในการเชื่อมต่อกับเซิร์ฟเวอร์',
          background: '#1d112e',
          color: '#fff'
        });
      }
    }

    document.querySelector('.search-container').addEventListener('submit', function (e) {
      const btn = this.querySelector('.btn-search');
      btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> กำลังค้นหา...';
      btn.disabled = true;
    });
  </script>


</body>

</html>
